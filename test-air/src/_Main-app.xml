<?xml version="1.0" encoding="UTF-8"?>
<application xmlns="http://ns.adobe.com/air/application/51.2">
  <id>com.fluocode.ane.test.signin</id>
  <filename>TestSignIn</filename>
  <name>
    <text xml:lang="en-US">Test SignIn</text>
  </name>
  <versionNumber>1.0.0</versionNumber>

  <supportedProfiles>mobileDevice</supportedProfiles>

  <initialWindow>
    <content>Main.swf</content>
    <fullScreen>true</fullScreen>
    <renderMode>direct</renderMode>
    <systemChrome>none</systemChrome>
    <autoOrients>true</autoOrients>
  </initialWindow>

  <extensions>
    <extensionID>com.fluocode.ane.signin.google</extensionID>
    <extensionID>com.fluocode.ane.signin.apple</extensionID>
  </extensions>

  <iPhone>
    <InfoAdditions>
      <![CDATA[
      <key>UIStatusBarStyle</key>
      <string>UIStatusBarStyleBlackOpaque</string>
      ]]>
    </InfoAdditions>
  </iPhone>
</application>

