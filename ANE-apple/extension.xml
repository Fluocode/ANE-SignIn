<?xml version="1.0" encoding="UTF-8"?>
<extension xmlns="http://ns.adobe.com/air/extension/22.0">
	<id>com.fluocode.ane.signin.apple</id>
	<versionNumber>1.0.0</versionNumber>
	<platforms>
		<platform name="iPhone-ARM">
			<applicationDeployment>
				<nativeLibrary>AppleSignInExtension.a</nativeLibrary>
				<initializer>AppleSignInExtensionInitializer</initializer>
				<finalizer>AppleSignInExtensionFinalizer</finalizer>
			</applicationDeployment>
		</platform>
		<platform name="iPhone-x86">
			<applicationDeployment>
				<nativeLibrary>AppleSignInExtension.a</nativeLibrary>
				<initializer>AppleSignInExtensionInitializer</initializer>
				<finalizer>AppleSignInExtensionFinalizer</finalizer>
			</applicationDeployment>
		</platform>
		<platform name="default">
			<applicationDeployment/>
		</platform>
	</platforms>
</extension>

